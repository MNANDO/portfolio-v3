---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogGrid from "@/components/BlogGrid";
import { loadPosts } from "@/lib/s3-loader";

const posts = await loadPosts();
---

<BaseLayout title="Blog — Michael Hernando">
  <section class="space-y-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
      <p class="mt-2 text-muted-foreground">Thoughts on code, building, and learning.</p>
    </div>

    <BlogGrid client:load posts={posts} />
  </section>
</BaseLayout>
